# ─── Ollama (Local LLM) ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Instagram / Meta ────────────────────────────────────
INSTA_VERIFY_TOKEN=your-webhook-verify-token
INSTA_ACCESS_TOKEN=your-instagram-access-token
INSTA_ACCOUNT_ID=your-instagram-account-id

# ─── iCloud CalDAV ───────────────────────────────────────
# Mettre à false pour utiliser le vrai calendrier Apple
CALENDAR_USE_MOCK=true
# URL du serveur CalDAV Apple (ne pas modifier)
CALDAV_URL=https://caldav.icloud.com
# Ton adresse email iCloud
CALDAV_EMAIL=tonemail@icloud.com
# Mot de passe d'application Apple (pas ton MDP iCloud !)
# Génère-le sur : appleid.apple.com → Sécurité → Mots de passe d'apps
CALDAV_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
